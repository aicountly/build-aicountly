# GitHub Actions secrets for build-aicountly
# Copy this file to secrets.local.env (git-ignored), paste values copied from
# reach-aicountly → Settings → Secrets and variables → Actions, then run:
#   .\.github\scripts\copy-secrets-from-reach.ps1 -EnvFile .github\secrets.local.env
#
# Or run without -EnvFile to push these placeholder defaults (update in GitHub later).

# --- cPanel SSH (copy identical values from reach-aicountly) ---
PROD_SFTP_REMOTE_ROOT=public_html
PROD_SFTP_HOST=UPDATE_FROM_REACH
PROD_SFTP_PORT=22
PROD_SFTP_USER=UPDATE_FROM_REACH
PROD_SSH_PRIVATE_KEY=UPDATE_FROM_REACH

# --- Frontend build (update host for build.aicountly.org) ---
VITE_API_URL=https://build.aicountly.org/api
VITE_APP_NAME=AICOUNTLY Build

# --- Superadmin seed on deploy ---
SUPER_ADMIN_EMAIL=pno@aicountly.com
SUPER_ADMIN_PASSWORD=UPDATE_ME
