{
    "name": "aicountly/build-api",
    "description": "AICOUNTLY Build Portal API (CodeIgniter 4.6 + PostgreSQL). Internal AI code-automation authority.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.6",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@composer dump-autoload"
        ],
        "migrate": "php spark migrate",
        "seed:owner": "php spark db:seed OwnerSeeder",
        "seed:repos": "php spark db:seed ReposSeeder",
        "seed:all": [
            "@seed:owner",
            "@seed:repos"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
