RewriteEngine On
RewriteBase /api/

# Pass Authorization header to PHP (required for JWT on Apache/CGI/FPM)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Also pass custom X-Worker-Token and X-Source headers for cross-portal integration
RewriteCond %{HTTP:X-Worker-Token} .
RewriteRule .* - [E=HTTP_X_WORKER_TOKEN:%{HTTP:X-Worker-Token}]
RewriteCond %{HTTP:X-Source} .
RewriteRule .* - [E=HTTP_X_SOURCE:%{HTTP:X-Source}]

# Block direct access to sensitive paths (CodeIgniter layout)
RewriteRule ^(app|database|writable|vendor|scripts)/ - [F,L]

<FilesMatch "^\.env">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
