# AICOUNTLY Build Portal API (CodeIgniter 4.6)
# Copy to server-php/.env; never commit a real .env.

CI_ENVIRONMENT=production
app.baseURL=https://build.aicountly.org/api/
app.indexPage=

#-----------------------------------------------------------------------
# PostgreSQL — Build portal database.
# All four values MUST come from this env. Config/Database.php never
# hardcodes credentials.
#-----------------------------------------------------------------------
BUILD_DB_HOST=127.0.0.1
BUILD_DB_PORT=5432
BUILD_DB_NAME=build_aicountly
BUILD_DB_USER=
BUILD_DB_PASSWORD=

#-----------------------------------------------------------------------
# Auth & encryption (generate strong random values; never commit real secrets).
# Generate:  php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
#-----------------------------------------------------------------------
BUILD_JWT_SECRET=
BUILD_JWT_TTL_MINUTES=720

# AES-256-GCM key (64 hex chars = 32 bytes). Used only by App\Libraries\Vault.
BUILD_VAULT_KEY=

#-----------------------------------------------------------------------
# CORS — comma-separated origins allowed to call the API.
#-----------------------------------------------------------------------
BUILD_ALLOWED_ORIGINS=https://build.aicountly.org,http://localhost:5173

#-----------------------------------------------------------------------
# Bot mode / defaults (surfaced in UI; stored in build_settings for
# live edits and mirrored back to Console).
#-----------------------------------------------------------------------
BUILD_BOT_MODE=confirm
BUILD_BOT_DEFAULT_RISK=medium

#-----------------------------------------------------------------------
# GitHub integration (backend-only; never exposed to frontend).
# When BUILD_GITHUB_TOKEN is empty, the GitHubService factory returns
# NullGitHubService and the UI shows "not configured".
#-----------------------------------------------------------------------
BUILD_GITHUB_TOKEN=
BUILD_GITHUB_ORG=AICOUNTLY
BUILD_GITHUB_API_BASE_URL=https://api.github.com
BUILD_GITHUB_DEFAULT_BRANCH=main
BUILD_GITHUB_WORKING_BRANCH_PREFIX=build-bot/

#-----------------------------------------------------------------------
# AI provider abstraction.
# BUILD_AI_PROVIDER selects the active adapter: claude | openai | aicountly | mock.
# Keys are ONLY read here and by the corresponding provider class.
#-----------------------------------------------------------------------
BUILD_AI_PROVIDER=mock

BUILD_AI_CLAUDE_API_KEY=
BUILD_AI_CLAUDE_MODEL=claude-sonnet-4
BUILD_AI_CLAUDE_API_BASE_URL=https://api.anthropic.com

BUILD_AI_OPENAI_API_KEY=
BUILD_AI_OPENAI_MODEL=gpt-4.1-mini
BUILD_AI_OPENAI_API_BASE_URL=https://api.openai.com

BUILD_AI_AICOUNTLY_API_URL=
BUILD_AI_AICOUNTLY_API_KEY=
BUILD_AI_AICOUNTLY_MODEL=aicountly-code-01

#-----------------------------------------------------------------------
# Playwright worker (worker.apis.aicountly.com). Screenshot / UI review only.
# Worker never has GitHub or bot logic (Part H of spec).
#-----------------------------------------------------------------------
BUILD_WORKER_BASE_URL=https://worker.apis.aicountly.com
BUILD_WORKER_API_TOKEN=

#-----------------------------------------------------------------------
# Flow inbound — Flow POSTs approved bug/feature handoffs here.
# Must equal Flow's BUILD_API_TOKEN in flow-react-app/server-php/.env.
# Optional HMAC secret for future signed webhooks.
#-----------------------------------------------------------------------
BUILD_FLOW_INBOUND_TOKEN=
BUILD_FLOW_INBOUND_HMAC_SECRET=

#-----------------------------------------------------------------------
# Console integration (outbound audit / approvals + inbound callback).
#-----------------------------------------------------------------------
BUILD_CONSOLE_API_BASE_URL=
BUILD_CONSOLE_API_TOKEN=
BUILD_CONSOLE_INBOUND_TOKEN=

#-----------------------------------------------------------------------
# Console controller SSO (identity introspect / launch token exchange).
# CONSOLE_API_URL is preferred; BUILD_CONSOLE_API_BASE_URL is a fallback.
#-----------------------------------------------------------------------
CONSOLE_API_URL=https://console.aicountly.org/api
CONTROLLER_APP_CODE=build

#-----------------------------------------------------------------------
# Optional deployment provider hook. If empty, DeploymentRequestService
# records the request but reports "provider not configured" to the UI.
#-----------------------------------------------------------------------
BUILD_DEPLOY_API_URL=
BUILD_DEPLOY_API_TOKEN=

#-----------------------------------------------------------------------
# Initial superadmin (OwnerSeeder).
# Also mirrored as SUPER_ADMIN_* GitHub secrets for deploy-production.yml
# (same names as reach-aicountly — copy those secrets, then update paths).
# Password is never committed; set locally in .env or in GitHub secrets.
#-----------------------------------------------------------------------
BUILD_OWNER_EMAIL=pno@aicountly.com
BUILD_OWNER_NAME="Build Superadmin"
# BUILD_OWNER_PASSWORD=

SUPER_ADMIN_EMAIL=pno@aicountly.com
SUPER_ADMIN_NAME="Build Superadmin"
# SUPER_ADMIN_PASSWORD=
